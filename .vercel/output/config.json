{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/blog/categories/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/blog/create/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/blog/edit/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/blog/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/media/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/messages/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/portfolio/create/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/portfolio/edit/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/portfolio/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/services/create/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/services/edit/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/services/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/settings/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/team/create/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/team/edit/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/team/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/upload/?$",
			"dest": "_render"
		},
		{
			"src": "^/blog/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/kontak/?$",
			"dest": "_render"
		},
		{
			"src": "^/layanan/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/layanan/?$",
			"dest": "_render"
		},
		{
			"src": "^/portfolio/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/sitemap\\.xml$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "/404.html",
			"status": 404
		}
	]
}
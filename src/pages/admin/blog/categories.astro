---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Kategori Blog | Admin Pinabae">
  <div class="mb-8 flex justify-between items-center">
    <div>
      <h1 class="text-2xl font-bold text-dark">Kategori Blog</h1>
      <p class="text-text">Kelola kategori untuk artikel blog Anda.</p>
    </div>
    <a href="/admin/blog" class="px-4 py-2 bg-gray-100 text-dark rounded-lg font-medium hover:bg-gray-200 transition-colors flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      Kembali ke Blog
    </a>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8" x-data="categoriesData()">
    <!-- Form Tambah Kategori -->
    <div class="lg:col-span-1">
      <div class="bg-white p-6 rounded-xl border border-border shadow-sm">
        <h2 class="text-lg font-bold text-dark mb-4">Tambah Kategori Baru</h2>
        <form @submit.prevent="addCategory" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-dark mb-1">Nama Kategori</label>
            <input type="text" x-model="newCategory.name" @input="generateSlug" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none" required placeholder="Contoh: Tips & Trik">
          </div>
          <div>
            <label class="block text-sm font-medium text-dark mb-1">Slug</label>
            <input type="text" x-model="newCategory.slug" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none bg-gray-50" required placeholder="tips-trik">
            <p class="text-xs text-gray-500 mt-1">URL ramah mesin pencari (otomatis terisi).</p>
          </div>
          <button type="submit" class="w-full py-2 bg-primary text-white rounded-lg font-bold hover:bg-orange-600 transition-colors flex justify-center items-center gap-2" :disabled="submitting">
            <span x-show="!submitting">Simpan Kategori</span>
            <span x-show="submitting" style="display: none;">
              <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
            </span>
          </button>
        </form>
      </div>
    </div>

    <!-- Tabel Kategori -->
    <div class="lg:col-span-2">
      <div class="bg-white rounded-xl border border-border shadow-sm overflow-hidden">
        <div class="p-4 border-b border-border bg-gray-50">
          <h2 class="font-semibold text-dark">Daftar Kategori</h2>
        </div>

        <div x-show="loading" class="p-12 text-center text-gray-400">
          <svg class="animate-spin h-8 w-8 mx-auto mb-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
          <p>Memuat kategori...</p>
        </div>

        <div x-show="!loading && categories.length === 0" class="p-12 text-center text-gray-500" style="display: none;">
          <p>Belum ada kategori. Silakan buat yang baru.</p>
        </div>

        <table x-show="!loading && categories.length > 0" class="w-full text-left" style="display: none;">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Nama</th>
              <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Slug</th>
              <th class="px-6 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Aksi</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <template x-for="category in categories" :key="category.id">
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-6 py-4">
                  <div class="font-medium text-dark" x-text="category.name"></div>
                </td>
                <td class="px-6 py-4">
                  <div class="text-sm text-gray-500 font-mono" x-text="category.slug"></div>
                </td>
                <td class="px-6 py-4 text-right">
                  <button @click="deleteCategory(category.id)" class="text-red-500 hover:text-red-700 text-sm font-medium">Hapus</button>
                </td>
              </tr>
            </template>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  import { supabase } from '../../../lib/supabase';

  document.addEventListener('alpine:init', () => {
    window.Alpine.data('categoriesData', () => ({
      categories: [],
      loading: true,
      submitting: false,
      newCategory: {
        name: '',
        slug: ''
      },

      async init() {
        await this.loadCategories();
      },

      async loadCategories() {
        this.loading = true;
        try {
          const { data, error } = await supabase
            .from('categories')
            .select('*')
            .order('name', { ascending: true });
            
          if (error) throw error;
          this.categories = data || [];
        } catch (error) {
          console.error('Error fetching categories:', error);
        } finally {
          this.loading = false;
        }
      },

      generateSlug() {
        this.newCategory.slug = this.newCategory.name
          .toLowerCase()
          .replace(/[^\w\s-]/g, '')
          .replace(/[\s_-]+/g, '-')
          .replace(/^-+|-+$/g, '');
      },

      async addCategory() {
        if (!this.newCategory.name || !this.newCategory.slug) return;
        this.submitting = true;

        try {
          const { data, error } = await supabase
            .from('categories')
            .insert([{ name: this.newCategory.name, slug: this.newCategory.slug }])
            .select();

          if (error) throw error;
          
          if (data && data.length > 0) {
            this.categories.push(data[0]);
            // Sort again
            this.categories.sort((a, b) => a.name.localeCompare(b.name));
            this.newCategory.name = '';
            this.newCategory.slug = '';
          }
        } catch (error) {
          console.error('Error adding category:', error);
          alert('Gagal menambahkan kategori. Pesan error: ' + (error.message || JSON.stringify(error)));
        } finally {
          this.submitting = false;
        }
      },

      async deleteCategory(id) {
        if (!confirm('Apakah Anda yakin ingin menghapus kategori ini? Pastikan tidak ada artikel yang terhubung dengan kategori ini.')) return;
        
        try {
          const { error } = await supabase
            .from('categories')
            .delete()
            .eq('id', id);
            
          if (error) throw error;
          this.categories = this.categories.filter(c => c.id !== id);
        } catch (error) {
          console.error('Error deleting category:', error);
          alert('Gagal menghapus kategori.');
        }
      }
    }));
  });
</script>

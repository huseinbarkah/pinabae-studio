---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Media Library | Admin Pinabae">
  <div class="mb-8 flex flex-col md:flex-row md:justify-between md:items-center gap-4">
    <div>
      <h1 class="text-2xl font-bold text-dark">Media Library</h1>
      <p class="text-text">Kelola semua gambar yang diunggah ke server.</p>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-border shadow-sm overflow-hidden" x-data="mediaData()">
    <div class="p-4 border-b border-border flex justify-between items-center bg-gray-50 flex-wrap gap-4">
      <div class="flex items-center gap-2">
        <label class="text-sm font-medium text-dark">Pilih Folder:</label>
        <select x-model="currentFolder" @change="loadMedia" class="px-3 py-1.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-primary/50 outline-none bg-white">
          <option value="blog">Blog</option>
          <option value="portfolio">Portfolio</option>
        </select>
      </div>

      <div class="flex items-center gap-3">
        <div class="text-sm text-gray-500 font-medium mr-4">
          Total: <span x-text="files.length" class="text-dark"></span> File
        </div>
        <button @click="loadMedia()" class="text-sm text-gray-500 hover:text-primary flex items-center gap-1 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" :class="{'animate-spin': loading}"><path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/></svg>
          Refresh
        </button>
      </div>
    </div>

    <!-- Loading State -->
    <div x-show="loading" class="p-12 text-center text-gray-400">
      <svg class="animate-spin h-8 w-8 mx-auto mb-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
      <p>Memuat media...</p>
    </div>

    <!-- Empty State -->
    <div x-show="!loading && files.length === 0" class="p-12 text-center text-gray-500" style="display: none;">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-4 text-gray-300"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
      <p class="text-lg font-medium text-dark mb-1">Folder Kosong</p>
      <p class="text-sm">Belum ada gambar yang diunggah ke folder ini.</p>
    </div>

    <!-- Media Grid -->
    <div x-show="!loading && files.length > 0" class="p-6" style="display: none;">
      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4">
        <template x-for="file in files" :key="file.id">
          <div class="group relative rounded-lg border border-gray-200 overflow-hidden bg-gray-50 aspect-square flex items-center justify-center">
            
            <!-- Image Thumbnail -->
            <img :src="file.publicUrl" :alt="file.name" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy">
            
            <!-- Overlay Actions -->
            <div class="absolute inset-0 bg-dark/60 opacity-0 group-hover:opacity-100 transition-opacity duration-200 flex flex-col items-center justify-center gap-3">
              
              <!-- Copy Link -->
              <button @click="copyLink(file.publicUrl)" class="bg-white text-dark text-xs font-bold px-3 py-1.5 rounded-md hover:bg-gray-100 flex items-center gap-1.5 transition-colors transform translate-y-2 group-hover:translate-y-0 duration-200" title="Copy URL">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
                Copy URL
              </button>
              
              <!-- Delete -->
              <button @click="deleteFile(file.name)" class="bg-red-500 text-white text-xs font-bold px-3 py-1.5 rounded-md hover:bg-red-600 flex items-center gap-1.5 transition-colors transform translate-y-2 group-hover:translate-y-0 duration-200 delay-75" title="Hapus Permanen">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                Hapus
              </button>

            </div>

            <!-- File Name & Size info overlay at bottom -->
            <div class="absolute bottom-0 left-0 right-0 p-2 bg-gradient-to-t from-dark/80 to-transparent pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity">
              <p class="text-white text-[10px] truncate" x-text="file.name"></p>
              <p class="text-gray-300 text-[10px]" x-text="formatSize(file.metadata.size)"></p>
            </div>
            
          </div>
        </template>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  import { supabase } from '../../../lib/supabase';

  document.addEventListener('alpine:init', () => {
    window.Alpine.data('mediaData', () => ({
      files: [],
      currentFolder: 'blog',
      loading: true,

      async init() {
        await this.loadMedia();
      },

      async loadMedia() {
        this.loading = true;
        try {
          const { data, error } = await supabase.storage
            .from('media')
            .list(this.currentFolder, {
              limit: 100,
              offset: 0,
              sortBy: { column: 'created_at', order: 'desc' },
            });
            
          if (error) {
            console.error('Bucket not found or access denied', error);
            this.files = [];
            return;
          }

          // Filter out .emptyFolderPlaceholder if any
          const validFiles = (data || []).filter(f => f.name !== '.emptyFolderPlaceholder' && f.id);
          
          // Generate public URLs for all valid files
          this.files = validFiles.map(file => {
            const { data: { publicUrl } } = supabase.storage
              .from('media')
              .getPublicUrl(`${this.currentFolder}/${file.name}`);
            
            return {
              ...file,
              publicUrl
            };
          });

        } catch (error) {
          console.error('Error fetching media:', error);
          alert('Gagal memuat media. Pastikan bucket "media" ada dan dapat diakses.');
        } finally {
          this.loading = false;
        }
      },

      async deleteFile(fileName) {
        if (!confirm(`Hapus file "${fileName}" secara permanen? Perhatian: Jika gambar ini masih digunakan di dalam artikel atau portfolio, gambar tersebut akan hilang (broken link).`)) return;
        
        try {
          const filePath = `${this.currentFolder}/${fileName}`;
          const { error } = await supabase.storage
            .from('media')
            .remove([filePath]);
            
          if (error) throw error;
          
          // Remove from local array to reflect UI
          this.files = this.files.filter(f => f.name !== fileName);
        } catch (error) {
          console.error('Error deleting file:', error);
          alert('Gagal menghapus file.');
        }
      },

      copyLink(url) {
        navigator.clipboard.writeText(url).then(() => {
          alert('URL gambar disalin ke clipboard!');
        }).catch(() => {
          alert('Gagal menyalin teks.');
        });
      },

      formatSize(bytes) {
        if (bytes === 0) return '0 Bytes';
        const k = 1024;
        const sizes = ['Bytes', 'KB', 'MB', 'GB'];
        const i = Math.floor(Math.log(bytes) / Math.log(k));
        return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
      }
    }));
  });
</script>

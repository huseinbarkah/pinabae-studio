---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Section from '../components/ui/Section.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import { supabase } from '../lib/supabase';

let services = [];
let portfolio = [];
let faqs = [];
let posts = [];

try {
  const { data: servicesData } = await supabase.from('services').select('*').limit(3);
  if (servicesData) services = servicesData;
  
  const { data: portfolioData } = await supabase.from('portfolio').select('*').limit(4);
  if (portfolioData) portfolio = portfolioData;
  
  const { data: faqsData } = await supabase.from('faqs').select('*').limit(5);
  if (faqsData) faqs = faqsData;
  
  const { data: postsData } = await supabase
    .from('blog_posts')
    .select('*, categories(name, slug)')
    .eq('status', 'published')
    .order('published_at', { ascending: false })
    .limit(3);
  if (postsData) posts = postsData;
} catch (error) {
  console.error('Supabase fetch error in index.astro:', error);
}
---

<Layout title="Pinabae Studio | Jasa Pembuatan Website Profesional">
	<Navbar />
	
	<main class="flex-grow">
		<!-- Hero Section -->
		<Section class="min-h-screen flex items-center pt-32 pb-20 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-orange-50 to-white -z-10"></div>
			<div class="text-center max-w-4xl mx-auto hero-content opacity-0 translate-y-8">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-border text-sm font-medium text-dark mb-8 shadow-sm">
          <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
          DIGITAL WEB STUDIO — SUMBAWA, NTB
        </div>
				<h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold text-orange-400 tracking-tight mb-8 text-balance leading-tight">
					PINABAE STUDIO <br class="hidden md:block"/> 
				</h1>
				<p class="text-lg md:text-xl text-text mb-12 text-balance leading-relaxed">
					Kami membantu UMKM, bisnis, perusahaan, freelancer, dan personal brand memiliki website modern yang cepat, responsif, dan SEO-friendly untuk meningkatkan kredibilitas, menjangkau lebih banyak pelanggan, dan memperkuat identitas digital.
				</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center">
          <Button href="/layanan" size="md">Konsultasi Sekarang</Button>
          <Button href="/portfolio" variant="outline" size="md">Lihat Hasil Karya</Button>
				</div>
			</div>
		</Section>

    <!-- Trusted By / Features -->
    <Section background="gray" class="py-16">
      <p class="text-center text-sm font-semibold text-gray-500 uppercase tracking-widest mb-10">Mengapa Memilih Pinabae Studio?</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 text-center">
        <Card class="feature-item opacity-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary mx-auto mb-5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          <h3 class="text-xl font-bold text-dark mb-3">Website Cepat Diakses</h3>
          <p class="text-text">Optimasi performa agar website memuat lebih cepat, memberikan pengalaman terbaik bagi setiap pengunjung.</p>
        </Card>
        <Card class="feature-item opacity-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary mx-auto mb-5"><path d="M18 8V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v7a2 2 0 0 0 2 2h8"/><path d="M10 19v-3.96 3.15"/><path d="M7 19h5"/><rect width="6" height="10" x="16" y="12" rx="2"/></svg>
          <h3 class="text-xl font-bold text-dark mb-3">Tampil Sempurna di Semua Perangkat</h3>
          <p class="text-text">Website tetap nyaman digunakan di smartphone, tablet, maupun desktop tanpa mengurangi kualitas tampilan.</p>
        </Card>
        <Card class="feature-item opacity-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary mx-auto mb-5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <h3 class="text-xl font-bold text-dark mb-3">Siap Bersaing di Google</h3>
          <p class="text-text">Dibangun dengan struktur SEO yang baik agar website lebih mudah ditemukan oleh calon pelanggan.</p>
        </Card>
        <Card class="feature-item opacity-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary mx-auto mb-5"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/></svg>
          <h3 class="text-xl font-bold text-dark mb-3">Desain Modern & Profesional</h3>
          <p class="text-text">Tampilan yang bersih, elegan, dan dirancang untuk meningkatkan kepercayaan terhadap bisnis Anda.</p>
        </Card>
      </div>
    </Section>

    <!-- Services Section -->
    <Section>
      <div class="text-center max-w-2xl mx-auto mb-16 section-header opacity-0">
        <h2 class="text-4xl md:text-5xl font-bold mb-6">Solusi Website untuk Mengembangkan Bisnis Anda</h2>
        <p class="text-lg text-text">Apa pun skala bisnis Anda, kami menghadirkan website yang tidak hanya menarik secara visual, tetapi juga mampu membangun kredibilitas dan mendukung pertumbuhan bisnis.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {services && services.length > 0 ? (
          services.map((service: any) => (
            <Card class="service-card opacity-0 flex flex-col h-full">
              <div class="w-12 h-12 bg-orange-100 text-primary rounded-xl flex items-center justify-center mb-6">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
              </div>
              <h3 class="text-2xl font-bold mb-4">{service.title}</h3>
              <p class="text-text mb-6 line-clamp-3 flex-grow">{service.description.replace(/<[^>]*>?/gm, '')}</p>
              <a href={`/layanan/${service.slug}`} class="text-primary font-medium hover:underline flex items-center gap-2 mt-auto">
                Pelajari Lebih Lanjut
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            </Card>
          ))
        ) : (
          [1, 2, 3].map(() => (
            <Card class="service-card opacity-0 flex flex-col h-full">
              <div class="w-12 h-12 bg-orange-100 text-primary rounded-xl flex items-center justify-center mb-6">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
              </div>
              <h3 class="text-2xl font-bold mb-4">Company Profile</h3>
              <p class="text-text mb-6 flex-grow">Bangun kredibilitas bisnis Anda dengan website profil perusahaan yang profesional dan meyakinkan.</p>
              <a href="/layanan" class="text-primary font-medium hover:underline flex items-center gap-2 mt-auto">
                Pelajari Lebih Lanjut
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            </Card>
          ))
        )}
      </div>
    </Section>

    <!-- Blog Preview Section -->
    <Section class="py-24 relative overflow-hidden bg-white border-t border-border/50">
      <!-- Soft Orange Blur Decoration -->
      <div class="absolute top-0 left-0 w-[600px] h-[600px] bg-orange-400/5 blur-3xl rounded-full pointer-events-none"></div>

      <div class="relative z-10 max-w-7xl mx-auto">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16 blog-header opacity-0 translate-y-8">
          <div class="max-w-2xl">
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-orange-50 text-orange-600 text-sm font-semibold mb-6 border border-orange-100">
              INSIGHT DIGITAL
            </div>
            <h2 class="text-4xl md:text-5xl font-extrabold text-dark tracking-tight mb-6 leading-tight">
              Artikel & Insight untuk Mengembangkan Bisnis Digital.
            </h2>
            <p class="text-lg text-text">
              Temukan berbagai artikel seputar website, SEO, branding, teknologi, dan strategi digital untuk membantu bisnis Anda berkembang.
            </p>
          </div>
          <a href="/blog" class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-white text-dark border border-gray-200 rounded-full font-semibold hover:bg-gray-50 hover:shadow-sm transition-all whitespace-nowrap mb-2">
            Lihat Semua Artikel
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {posts && posts.length > 0 ? (
            posts.map((post: any) => (
              <a href={`/blog/${post.slug}`} class="group block blog-card opacity-0 translate-y-12 h-full">
                <div class="bg-white rounded-[24px] border border-gray-200 overflow-hidden shadow-sm hover:shadow-xl hover:shadow-orange-500/5 transition-all duration-500 hover:-translate-y-2 flex flex-col h-full">
                  <div class="relative h-60 overflow-hidden bg-gray-100">
                    {post.featured_image ? (
                      <img src={post.featured_image} alt={post.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
                    ) : (
                      <div class="w-full h-full flex items-center justify-center text-gray-400">No Image</div>
                    )}
                    {post.categories && (
                      <div class="absolute top-4 left-4">
                        <span class="px-3 py-1.5 bg-white/90 backdrop-blur-md text-dark text-xs font-bold rounded-full shadow-sm">{post.categories.name}</span>
                      </div>
                    )}
                  </div>
                  <div class="p-6 md:p-8 flex-grow flex flex-col">
                    <h3 class="text-xl md:text-2xl font-bold text-dark mb-4 leading-snug group-hover:text-orange-500 transition-colors">
                      {post.title}
                    </h3>
                    <p class="text-text mb-8 line-clamp-2 flex-grow">
                      {post.excerpt}
                    </p>
                    <div class="flex items-center justify-between text-sm text-gray-500 font-medium pt-5 border-t border-gray-100 mt-auto">
                      <span>{post.published_at ? new Date(post.published_at).toLocaleDateString('id-ID', { year: 'numeric', month: 'short', day: 'numeric' }) : 'Unknown Date'}</span>
                      <span class="flex items-center gap-1.5">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> 
                        Baca Artikel
                      </span>
                    </div>
                  </div>
                </div>
              </a>
            ))
          ) : (
            [1, 2, 3].map(() => (
              <div class="group block blog-card opacity-0 translate-y-12 h-full">
                <div class="bg-white rounded-[24px] border border-gray-200 overflow-hidden shadow-sm flex flex-col h-full">
                  <div class="relative h-60 overflow-hidden bg-gray-100 animate-pulse"></div>
                  <div class="p-6 md:p-8 flex-grow flex flex-col">
                    <div class="h-6 bg-gray-200 rounded w-3/4 mb-4 animate-pulse"></div>
                    <div class="h-4 bg-gray-200 rounded w-full mb-2 animate-pulse"></div>
                    <div class="h-4 bg-gray-200 rounded w-5/6 mb-8 animate-pulse"></div>
                    <div class="flex items-center justify-between mt-auto">
                      <div class="h-4 bg-gray-200 rounded w-1/4 animate-pulse"></div>
                      <div class="h-4 bg-gray-200 rounded w-1/4 animate-pulse"></div>
                    </div>
                  </div>
                </div>
              </div>
            ))
          )}
        </div>
      </div>
    </Section>

    <div class="h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent max-w-7xl mx-auto my-4"></div>

    <!-- CTA Section -->
    <Section class="py-24">
      <div class="max-w-5xl mx-auto cta-content opacity-0 translate-y-12 scale-95 relative overflow-hidden bg-[#F8FAFC] border border-gray-200 rounded-[32px] p-10 md:p-16 lg:p-20 text-center shadow-sm">
        <!-- Soft Orange Blur Decoration -->
        <div class="absolute -top-32 -right-32 w-[500px] h-[500px] bg-orange-400/10 blur-3xl rounded-full pointer-events-none"></div>

        <div class="relative z-10">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-gray-200 text-sm font-semibold text-dark mb-8 shadow-sm">
            <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
            Konsultasi Gratis
          </div>
          
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-dark tracking-tight mb-8 text-balance leading-tight">
            Saatnya Bisnis Anda <br class="hidden md:block"/> Tampil Lebih Profesional
          </h2>
          
          <p class="text-lg md:text-xl text-text mb-12 text-balance leading-relaxed max-w-3xl mx-auto">
            Website bukan sekadar identitas digital, tetapi investasi untuk membangun kepercayaan pelanggan. Pinabae Studio siap membantu Anda merancang website yang modern, cepat, responsif, dan sesuai dengan tujuan bisnis Anda. Konsultasikan kebutuhan Anda sekarang tanpa biaya.
          </p>

          <div class="flex flex-wrap justify-center items-center gap-4 md:gap-8 mb-14 text-sm md:text-base font-semibold text-dark">
            <div class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-green-500"><path d="M20 6 9 17l-5-5"/></svg>
              Konsultasi Gratis
            </div>
            <div class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-green-500"><path d="M20 6 9 17l-5-5"/></svg>
              Harga Transparan
            </div>
            <div class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-green-500"><path d="M20 6 9 17l-5-5"/></svg>
              Proses Mudah
            </div>
            <div class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-green-500"><path d="M20 6 9 17l-5-5"/></svg>
              Support Setelah Website Selesai
            </div>
          </div>
          
          <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
            <a href="https://wa.me/6281234567890" target="_blank" rel="noopener noreferrer" class="group flex items-center justify-center gap-2 px-8 py-4 bg-[#F57C00] text-white rounded-full font-bold text-lg hover:bg-[#E65100] hover:scale-105 hover:-translate-y-1 hover:shadow-xl hover:shadow-orange-500/20 transition-all duration-300 w-full sm:w-auto">
              Konsultasi via WhatsApp
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-1.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
            <a href="/portfolio" class="flex items-center justify-center px-8 py-4 bg-white text-dark border border-gray-200 rounded-full font-bold text-lg hover:bg-gray-50 hover:scale-105 hover:-translate-y-1 transition-all duration-300 shadow-sm hover:shadow w-full sm:w-auto">
              Lihat Portfolio
            </a>
          </div>
        </div>
      </div>
    </Section>
	</main>

	<Footer />
</Layout>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Initial Hero Animation
  gsap.to('.hero-content', {
    opacity: 1,
    y: 0,
    duration: 1,
    ease: 'power3.out',
    delay: 0.2
  });

  // Features Animation
  gsap.to('.feature-item', {
    scrollTrigger: {
      trigger: '.feature-item',
      start: 'top 80%',
    },
    opacity: 1,
    y: 0,
    stagger: 0.1,
    duration: 0.8,
    ease: 'power2.out'
  });

  // Section Headers Animation
  gsap.utils.toArray('.section-header').forEach((header: any) => {
    gsap.to(header, {
      scrollTrigger: {
        trigger: header,
        start: 'top 85%',
      },
      opacity: 1,
      y: 0,
      duration: 0.8,
      ease: 'power2.out'
    });
  });

  // Cards Animation
  gsap.to('.service-card', {
    scrollTrigger: {
      trigger: '.service-card',
      start: 'top 80%',
    },
    opacity: 1,
    y: 0,
    stagger: 0.15,
    duration: 0.8,
    ease: 'power2.out'
  });

  // Blog Header Animation
  gsap.to('.blog-header', {
    scrollTrigger: {
      trigger: '.blog-header',
      start: 'top 85%',
    },
    opacity: 1,
    y: 0,
    duration: 0.8,
    ease: 'power2.out'
  });

  // Blog Cards Animation
  gsap.to('.blog-card', {
    scrollTrigger: {
      trigger: '.blog-card',
      start: 'top 80%',
    },
    opacity: 1,
    y: 0,
    stagger: 0.15,
    duration: 0.8,
    ease: 'power2.out'
  });

  // CTA Animation
  gsap.to('.cta-content', {
    scrollTrigger: {
      trigger: '.cta-content',
      start: 'top 80%',
    },
    opacity: 1,
    y: 0,
    scale: 1,
    duration: 1,
    ease: 'power3.out'
  });
</script>

---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Section from '../components/ui/Section.astro';
import Button from '../components/ui/Button.astro';
---

<Layout title="Halaman Tidak Ditemukan | Pinabae Studio">
  <Navbar />
  
  <main class="flex-grow pt-32 flex flex-col justify-center min-h-[70vh]">
    <Section class="text-center">
      <h1 class="text-7xl md:text-9xl font-extrabold text-primary mb-6">404</h1>
      <h2 class="text-3xl font-bold text-dark mb-4">Halaman Tidak Ditemukan</h2>
      <p class="text-lg text-text mb-10 max-w-lg mx-auto">Maaf, halaman yang Anda cari tidak ada atau telah dipindahkan.</p>
      <Button href="/">Kembali ke Beranda</Button>
    </Section>
  </main>

  <Footer />
</Layout>

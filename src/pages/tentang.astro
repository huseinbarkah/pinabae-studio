---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Section from '../components/ui/Section.astro';
import { supabase } from '../lib/supabase';

const { data: teamMembers } = await supabase
  .from('team_members')
  .select('*')
  .order('created_at', { ascending: true });
---

<Layout title="Tentang Kami | Pinabae Studio" description="Pinabae Studio adalah digital agency yang berfokus pada pembuatan website berkualitas tinggi.">
  <Navbar />
  
  <main class="flex-grow pt-32">
    <Section class="text-center pb-16">
      <div class="max-w-3xl mx-auto header-anim opacity-0 translate-y-8">
        <h1 class="text-5xl md:text-7xl font-extrabold text-dark tracking-tight mb-8">Pina<span class="text-primary">Bae</span></h1>
        <p class="text-xl text-text text-balance">
           <b>Pinabae</b> berasal dari bahasa Sumbawa yang berarti <b>"Buat Saja."</b>
Filosofi ini menjadi pengingat bahwa membangun kehadiran digital tidak harus rumit. Kami membantu bisnis, UMKM, dan personal brand memiliki website profesional yang modern, cepat, dan siap mendukung pertumbuhan bisnis.
        </p>
      </div>
    </Section>

    <Section>
      <!-- Top Section -->
      <div class="flex flex-col lg:flex-row gap-6 lg:gap-16 justify-between items-start mb-16 fade-up-anim opacity-0 translate-y-8">
        <div class="lg:w-1/2">
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-dark tracking-tight leading-[1.1]">
            Mengapa Memilih <br class="hidden lg:block" />
            <span class="text-primary">Pinabae Studio</span>
          </h2>
        </div>
        
        <div class="lg:w-1/2 lg:pt-4">
          <p class="text-lg md:text-xl text-text leading-relaxed text-balance">
            Kami membangun website yang tidak hanya menarik secara visual, tetapi juga cepat, responsif, dan dirancang untuk membantu bisnis tampil lebih profesional serta dipercaya oleh pelanggan.
          </p>
        </div>
      </div>

      <!-- Subtle Divider -->
      <div class="w-full h-px bg-gray-200/60 mb-16 fade-up-anim opacity-0 translate-y-4"></div>

      <!-- Four Premium Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 card-grid">
        <!-- Card 1 -->
        <div class="card-anim opacity-0 translate-y-8">
          <div class="h-full group bg-white rounded-[24px] p-8 lg:p-10 border border-gray-200/60 transition-all duration-500 ease-out hover:-translate-y-1.5 hover:border-primary/30 hover:shadow-[0_8px_30px_rgb(245,124,0,0.12)]">
            <div class="w-14 h-14 rounded-2xl bg-orange-50/50 flex items-center justify-center mb-8 group-hover:scale-110 group-hover:bg-orange-100 transition-all duration-500 ease-out">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary lucide lucide-layout"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><line x1="3" x2="21" y1="9" y2="9"/><line x1="9" x2="9" y1="21" y2="9"/></svg>
            </div>
            <h3 class="text-2xl font-bold text-dark mb-4 tracking-tight">Desain Modern</h3>
            <p class="text-text leading-relaxed">
              Setiap website dirancang dengan tampilan yang bersih, profesional, dan mudah digunakan agar memberikan kesan pertama yang positif bagi pengunjung.
            </p>
          </div>
        </div>

        <!-- Card 2 -->
        <div class="card-anim opacity-0 translate-y-8">
          <div class="h-full group bg-white rounded-[24px] p-8 lg:p-10 border border-gray-200/60 transition-all duration-500 ease-out hover:-translate-y-1.5 hover:border-primary/30 hover:shadow-[0_8px_30px_rgb(245,124,0,0.12)]">
            <div class="w-14 h-14 rounded-2xl bg-orange-50/50 flex items-center justify-center mb-8 group-hover:scale-110 group-hover:bg-orange-100 transition-all duration-500 ease-out">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary lucide lucide-zap"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            </div>
            <h3 class="text-2xl font-bold text-dark mb-4 tracking-tight">Performa Cepat</h3>
            <p class="text-text leading-relaxed">
              Website dioptimalkan agar memiliki waktu muat yang cepat, responsif di berbagai perangkat, dan memberikan pengalaman pengguna yang nyaman.
            </p>
          </div>
        </div>

        <!-- Card 3 -->
        <div class="card-anim opacity-0 translate-y-8">
          <div class="h-full group bg-white rounded-[24px] p-8 lg:p-10 border border-gray-200/60 transition-all duration-500 ease-out hover:-translate-y-1.5 hover:border-primary/30 hover:shadow-[0_8px_30px_rgb(245,124,0,0.12)]">
            <div class="w-14 h-14 rounded-2xl bg-orange-50/50 flex items-center justify-center mb-8 group-hover:scale-110 group-hover:bg-orange-100 transition-all duration-500 ease-out">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary lucide lucide-search"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            </div>
            <h3 class="text-2xl font-bold text-dark mb-4 tracking-tight">SEO Friendly</h3>
            <p class="text-text leading-relaxed">
              Kami menerapkan praktik terbaik SEO sejak awal pengembangan agar website lebih mudah ditemukan melalui mesin pencari.
            </p>
          </div>
        </div>

        <!-- Card 4 -->
        <div class="card-anim opacity-0 translate-y-8">
          <div class="h-full group bg-white rounded-[24px] p-8 lg:p-10 border border-gray-200/60 transition-all duration-500 ease-out hover:-translate-y-1.5 hover:border-primary/30 hover:shadow-[0_8px_30px_rgb(245,124,0,0.12)]">
            <div class="w-14 h-14 rounded-2xl bg-orange-50/50 flex items-center justify-center mb-8 group-hover:scale-110 group-hover:bg-orange-100 transition-all duration-500 ease-out">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary lucide lucide-life-buoy"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/><line x1="4.93" x2="9.17" y1="4.93" y2="9.17"/><line x1="14.83" x2="19.07" y1="14.83" y2="19.07"/><line x1="14.83" x2="19.07" y1="9.17" y2="4.93"/><line x1="14.83" x2="19.07" y1="9.17" y2="4.93" /><line x1="4.93" x2="9.17" y1="19.07" y2="14.83"/></svg>
            </div>
            <h3 class="text-2xl font-bold text-dark mb-4 tracking-tight">Dukungan Berkelanjutan</h3>
            <p class="text-text leading-relaxed">
              Kami tetap mendampingi Anda setelah website selesai melalui konsultasi, pembaruan, dan dukungan teknis sesuai kebutuhan.
            </p>
          </div>
        </div>
      </div>
    </Section>

    <Section>
      <!-- Top Section -->
      <div class="flex flex-col lg:flex-row gap-6 lg:gap-16 justify-between items-start mb-16 fade-up-anim opacity-0 translate-y-8">
        <div class="lg:w-1/2">
          <span class="inline-block text-primary font-bold tracking-wider text-sm mb-4 uppercase">Tim Pinabae Studio</span>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-dark tracking-tight leading-[1.1]">
            Orang-Orang di Balik <br class="hidden lg:block" />
            Pinabae Studio
          </h2>
        </div>
        
        <div class="lg:w-1/2 lg:pt-10">
          <p class="text-lg md:text-xl text-text leading-relaxed text-balance">
            Setiap website yang kami bangun merupakan hasil kolaborasi antara kreativitas, strategi, dan teknologi. Kami percaya bahwa komunikasi yang baik, perhatian terhadap detail, dan proses yang transparan adalah kunci untuk menghasilkan solusi digital yang benar-benar memberikan nilai bagi setiap bisnis.
          </p>
        </div>
      </div>

      <!-- Subtle Divider -->
      <div class="w-full h-px bg-gray-200/60 mb-16 fade-up-anim opacity-0 translate-y-4"></div>

      <!-- Team Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 card-grid">
        {teamMembers && teamMembers.length > 0 ? (
          teamMembers.map((member: any) => (
            <div class="card-anim opacity-0 translate-y-8 h-full">
              <div class="h-full group bg-white rounded-[24px] border border-gray-200/60 transition-all duration-500 ease-out hover:-translate-y-1.5 hover:border-primary/30 hover:shadow-[0_8px_30px_rgb(245,124,0,0.12)] flex flex-col p-3">
                <div class="relative h-72 md:h-80 w-full overflow-hidden rounded-[20px] bg-gray-100 mb-4">
                  {member.photo_url ? (
                    <img src={member.photo_url} alt={member.name} class="w-full h-full object-cover transition-all duration-700 ease-out grayscale group-hover:grayscale-0 group-hover:scale-105" />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center text-gray-400">
                      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    </div>
                  )}

                  {/* Floating LinkedIn Icon like in screenshot */}
                  {member.linkedin_url && (
                    <a href={member.linkedin_url} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="absolute bottom-3 right-3 w-10 h-10 bg-[#0A66C2] rounded-[10px] border-2 border-white flex items-center justify-center text-white hover:bg-blue-700 transition-all duration-300 shadow-sm translate-y-2 opacity-0 group-hover:translate-y-0 group-hover:opacity-100">
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                    </a>
                  )}
                </div>

                <div class="px-3 pb-3 flex flex-col flex-grow">
                  <h3 class="text-[20px] font-bold text-dark tracking-tight mb-1">{member.name}</h3>
                  <p class="text-[11px] font-bold text-gray-500 uppercase tracking-wider mb-4">{member.position}</p>
                  
                  {member.biography && (
                    <p class="text-sm text-text leading-relaxed flex-grow">
                      {member.biography}
                    </p>
                  )}
                  
                  {member.instagram_url && (
                    <div class="mt-4 pt-4 border-t border-gray-100 flex gap-3">
                      <a href={member.instagram_url} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="w-9 h-9 rounded-full bg-gray-50 flex items-center justify-center text-gray-500 hover:bg-orange-50 hover:text-primary transition-colors duration-300">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-instagram"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
                      </a>
                    </div>
                  )}
                </div>
              </div>
            </div>
          ))
        ) : (
          <div class="col-span-full text-center py-12 text-gray-500">
            Tim belum ditambahkan.
          </div>
        )}
      </div>
    </Section>
  </main>

  <Footer />
</Layout>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.to('.header-anim', { opacity: 1, y: 0, duration: 1, ease: 'power3.out' });
  
  gsap.utils.toArray('.content-anim').forEach((el: any) => {
    gsap.to(el, {
      scrollTrigger: {
        trigger: el,
        start: 'top 80%',
      },
      opacity: 1,
      x: 0,
      duration: 0.8,
      ease: 'power2.out'
    });
  });

  gsap.utils.toArray('.fade-up-anim').forEach((el: any) => {
    gsap.to(el, {
      scrollTrigger: {
        trigger: el,
        start: 'top 80%',
      },
      opacity: 1,
      y: 0,
      duration: 0.8,
      ease: 'power3.out'
    });
  });

  gsap.utils.toArray('.card-grid').forEach((grid: any) => {
    gsap.to(grid.querySelectorAll('.card-anim'), {
      scrollTrigger: {
        trigger: grid,
        start: 'top 80%',
      },
      opacity: 1,
      y: 0,
      duration: 0.8,
      stagger: 0.1,
      ease: 'power3.out'
    });
  });

</script>

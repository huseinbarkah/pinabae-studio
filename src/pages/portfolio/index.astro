---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Section from '../../components/ui/Section.astro';
import Card from '../../components/ui/Card.astro';
import { supabase } from '../../lib/supabase';

const { data: portfolios } = await supabase.from('portfolio').select('*').order('created_at', { ascending: false });
---

<Layout title="Portfolio | Pinabae Studio" description="Kumpulan hasil karya website terbaik dari Pinabae Studio.">
  <Navbar />

  <main class="flex-grow pt-24">
    <!-- Header -->
    <Section class="pb-10 md:pb-16 text-center">
      <div class="max-w-3xl mx-auto header-anim opacity-0 translate-y-8">
        <h1 class="text-4xl md:text-6xl font-extrabold text-dark tracking-tight mb-6">Hasil <span class="text-primary">Karya Kami</span></h1>
        <p class="text-xl text-text">Jelajahi berbagai proyek website sukses yang telah kami bangun untuk berbagai jenis bisnis.</p>
      </div>
    </Section>

    <!-- Portfolio Grid -->
    <Section background="gray" class="py-16 md:py-24">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
        {portfolios && portfolios.length > 0 ? (
          portfolios.map((item: any) => (
            <Card class="portfolio-card opacity-0 translate-y-8 p-0" hover={true}>
              <a href={`/portfolio/${item.slug}`} class="block group">
                <div class="aspect-[4/3] bg-gray-200 overflow-hidden relative">
                  {item.image_url ? (
                    <img src={item.image_url} alt={item.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center text-gray-400">No Image</div>
                  )}
                  <div class="absolute inset-0 bg-dark/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                </div>
                <div class="p-6">
                  <div class="text-xs font-semibold text-primary uppercase tracking-wider mb-2">
                    {item.client_name || 'Project'}
                  </div>
                  <h2 class="text-2xl font-bold text-dark mb-3 group-hover:text-primary transition-colors">{item.title}</h2>
                  <p class="text-text line-clamp-2">{item.description}</p>
                </div>
              </a>
            </Card>
          ))
        ) : (
          [1, 2, 3, 4].map((i) => (
            <Card class="portfolio-card opacity-0 translate-y-8 p-0" hover={true}>
              <div class="block group cursor-pointer">
                <div class="aspect-[4/3] bg-gray-200 overflow-hidden relative">
                  <div class="w-full h-full flex items-center justify-center bg-gray-300 text-gray-500">Image Placeholder {i}</div>
                </div>
                <div class="p-6">
                  <div class="text-xs font-semibold text-primary uppercase tracking-wider mb-2">Client Name</div>
                  <h2 class="text-2xl font-bold text-dark mb-3 group-hover:text-primary transition-colors">Project Title {i}</h2>
                  <p class="text-text line-clamp-2">Deskripsi singkat mengenai proyek website ini dan hasil yang dicapai.</p>
                </div>
              </div>
            </Card>
          ))
        )}
      </div>
    </Section>
  </main>

  <Footer />
</Layout>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.to('.header-anim', { opacity: 1, y: 0, duration: 1, ease: 'power3.out' });

  gsap.to('.portfolio-card', {
    scrollTrigger: {
      trigger: '.portfolio-card',
      start: 'top 85%',
    },
    opacity: 1,
    y: 0,
    stagger: 0.15,
    duration: 0.8,
    ease: 'power2.out'
  });
</script>

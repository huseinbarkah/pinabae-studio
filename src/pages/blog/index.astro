---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Section from '../../components/ui/Section.astro';
import Card from '../../components/ui/Card.astro';
import { supabase } from '../../lib/supabase';

// Fetch published blog posts
const { data: posts } = await supabase
  .from('blog_posts')
  .select('*, categories(name, slug)')
  .eq('status', 'published')
  .order('published_at', { ascending: false });
---

<Layout title="Blog | Pinabae Studio" description="Artikel, wawasan, dan tips terbaru seputar website, desain, dan bisnis digital.">
  <Navbar />
  
  <main class="flex-grow pt-24">
    <Section class="pb-10 md:pb-16 text-center">
      <div class="max-w-3xl mx-auto header-anim opacity-0 translate-y-8">
        <h1 class="text-4xl md:text-6xl font-extrabold text-dark tracking-tight mb-6">Wawasan & <span class="text-primary">Edukasi</span></h1>
        <p class="text-xl text-text">Artikel terbaru tentang desain website, strategi digital, dan pengembangan bisnis.</p>
      </div>
    </Section>

    <Section background="gray" class="py-16 md:py-24">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts && posts.length > 0 ? (
          posts.map((post: any) => (
            <Card class="post-card opacity-0 translate-y-8 flex flex-col p-0" hover={true}>
              <a href={`/blog/${post.slug}`} class="block group h-full flex flex-col">
                <div class="aspect-video bg-gray-200 overflow-hidden relative">
                  {post.featured_image ? (
                    <img src={post.featured_image} alt={post.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center text-gray-400">No Image</div>
                  )}
                </div>
                <div class="p-6 flex flex-col flex-grow">
                  <div class="flex items-center gap-3 text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">
                    {post.categories && <span class="text-primary">{post.categories.name}</span>}
                    {post.published_at && (
                      <>
                        <span>&bull;</span>
                        <span>{new Date(post.published_at).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                      </>
                    )}
                  </div>
                  <h2 class="text-xl font-bold text-dark mb-3 group-hover:text-primary transition-colors">{post.title}</h2>
                  <p class="text-text line-clamp-3 mb-6 flex-grow">{post.excerpt}</p>
                  <span class="text-primary font-medium text-sm flex items-center gap-1 mt-auto">
                    Baca Artikel <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  </span>
                </div>
              </a>
            </Card>
          ))
        ) : (
          [1, 2, 3].map((i) => (
            <Card class="post-card opacity-0 translate-y-8 flex flex-col p-0" hover={true}>
              <div class="block group h-full flex flex-col cursor-pointer">
                <div class="aspect-video bg-gray-200 overflow-hidden relative">
                  <div class="w-full h-full flex items-center justify-center bg-gray-300 text-gray-500">Image Placeholder</div>
                </div>
                <div class="p-6 flex flex-col flex-grow">
                  <div class="flex items-center gap-3 text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">
                    <span class="text-primary">Kategori</span>
                    <span>&bull;</span>
                    <span>16 Juli 2026</span>
                  </div>
                  <h2 class="text-xl font-bold text-dark mb-3 group-hover:text-primary transition-colors">Judul Artikel Blog {i}</h2>
                  <p class="text-text line-clamp-3 mb-6 flex-grow">Ini adalah kutipan artikel blog yang memberikan gambaran singkat tentang isi artikel. Sangat bermanfaat untuk SEO.</p>
                  <span class="text-primary font-medium text-sm flex items-center gap-1 mt-auto">
                    Baca Artikel <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  </span>
                </div>
              </div>
            </Card>
          ))
        )}
      </div>
    </Section>
  </main>

  <Footer />
</Layout>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.to('.header-anim', { opacity: 1, y: 0, duration: 1, ease: 'power3.out' });

  gsap.to('.post-card', {
    scrollTrigger: {
      trigger: '.post-card',
      start: 'top 85%',
    },
    opacity: 1,
    y: 0,
    stagger: 0.1,
    duration: 0.8,
    ease: 'power2.out'
  });
</script>
